#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="mm-harness"

usage() {
  cat <<'USAGE'
Usage:
  mm-harness                         # auto-detect repo, install into current dir
  mm-harness install                 # auto-detect repo, install into current dir
  mm-harness verify [args]           # auto-detect repo, verify current dir
  mm-harness cleanup [args]          # auto-detect repo, cleanup current dir
  mm-harness --target <repo> install
  mm-harness --adapter <mobile|extension> verify --cdp-port <port>

Explicit low-level form is also supported:
  mm-harness <mobile|extension> <install|verify|cleanup> [args]

Common examples:
  mm-harness
  mm-harness verify --static-only
  mm-harness verify --no-auto-start
  mm-harness verify --cdp-port 6662
  mm-harness verify --preflight-mode fast
  mm-harness --target ~/dev/metamask/metamask-extension-2 verify --cdp-port 6662

Mobile runtime configuration:
  MM_HARNESS_MOBILE_PREFLIGHT_MODE=fast # default; reuse installed/cache, fail before native rebuild
  MM_HARNESS_MOBILE_PREFLIGHT_MODE=auto # allow fingerprint-gated native build on cache miss

Extension runtime configuration:
  MM_HARNESS_EXTENSION_AUTO_START=0      # never launch a missing browser
  MM_HARNESS_EXTENSION_PREPARE_CMD='...' # custom command for non-Farmslot repos
  MM_HARNESS_EXTENSION_PREPARE_WATCH=on  # Farmslot preflight watch mode (default: off)
USAGE
}

log() { printf '[%s] %s\n' "$SCRIPT_NAME" "$*" >&2; }
fail() { printf '[%s] ERROR: %s\n' "$SCRIPT_NAME" "$*" >&2; exit 1; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RECIPE_HARNESS="$SCRIPT_DIR/recipe-harness.sh"
[ -x "$RECIPE_HARNESS" ] || fail "missing recipe-harness.sh next to $0"

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

case "${1:-}" in
  mobile|extension)
    # Backwards-compatible explicit form with nicer progress output.
    ADAPTER="$1"
    ACTION="${2:-}"
    [ -n "$ACTION" ] || { usage >&2; exit 2; }
    shift 2
    ;;
  *)
    ADAPTER=""
    ACTION="install"
    TARGET="$PWD"
    PASSTHRU=()
    while [ "$#" -gt 0 ]; do
      case "$1" in
        install|verify|cleanup)
          ACTION="$1"
          shift
          ;;
        --adapter)
          ADAPTER="$2"
          shift 2
          ;;
        --target|-C)
          TARGET="$2"
          shift 2
          ;;
        --)
          shift
          PASSTHRU+=("$@")
          break
          ;;
        *)
          PASSTHRU+=("$1")
          shift
          ;;
      esac
    done
    TARGET="$(cd "$TARGET" && pwd)"

    detect_adapter() {
      local target="$1"
      local remote=""
      remote="$(git -C "$target" config --get remote.origin.url 2>/dev/null || true)"
      case "$remote" in
        *metamask-extension*) printf 'extension\n'; return 0 ;;
        *metamask-mobile*) printf 'mobile\n'; return 0 ;;
      esac

      # Repo-shape fallback for worktrees/clones with unusual remote names.
      if [ -f "$target/development/skills-sync.ts" ] || { [ -d "$target/ui" ] && [ -d "$target/app/scripts" ]; }; then
        printf 'extension\n'
        return 0
      fi
      if [ -f "$target/scripts/skills-sync.mts" ] || { [ -d "$target/ios" ] && [ -d "$target/android" ] && [ -d "$target/app/core" ]; }; then
        printf 'mobile\n'
        return 0
      fi
      return 1
    }

    if [ -z "$ADAPTER" ]; then
      ADAPTER="$(detect_adapter "$TARGET")" || fail "could not detect MetaMask repo type for $TARGET; pass --adapter mobile or --adapter extension"
    fi

    set -- "${PASSTHRU[@]}"
    ;;
esac

case "$ADAPTER:$ACTION" in
  mobile:install|mobile:verify|mobile:cleanup|extension:install|extension:verify|extension:cleanup) ;;
  *) usage >&2; fail "unsupported adapter/action: ${ADAPTER:-?}/${ACTION:-?}" ;;
esac

# In explicit form, TARGET may not be set. Try to discover it from args for display only.
if [ -z "${TARGET:-}" ]; then
  TARGET="$PWD"
  args=("$@")
  for ((i=0; i<${#args[@]}; i++)); do
    if [ "${args[$i]}" = "--target" ] && [ $((i + 1)) -lt ${#args[@]} ]; then
      TARGET="${args[$((i + 1))]}"
      break
    fi
  done
  TARGET="$(cd "$TARGET" 2>/dev/null && pwd || printf '%s' "$TARGET")"
else
  # Smart form owns --target injection so humans can omit it.
  set -- --target "$TARGET" "$@"
fi

case "$ACTION" in
  install) VERB="Installing" ;;
  verify) VERB="Verifying" ;;
  cleanup) VERB="Cleaning" ;;
esac

log "$VERB $ADAPTER recipe harness"
log "Target: $TARGET"
has_arg() {
  local needle="$1"
  shift
  for arg in "$@"; do
    [ "$arg" = "$needle" ] && return 0
    case "$arg" in "$needle="*) return 0 ;; esac
  done
  return 1
}

cdp_reachable() {
  local port="$1"
  command -v curl >/dev/null 2>&1 || return 1
  curl -fsS --max-time 1 "http://127.0.0.1:${port}/json/version" >/dev/null 2>&1
}

is_false() {
  case "${1:-}" in
    0|false|FALSE|False|no|NO|No|off|OFF|Off) return 0 ;;
    *) return 1 ;;
  esac
}

resolve_extension_farmslot_metadata() {
  local target="$1"
  local farmslot_dir="${FARMSLOT_DIR:-}"
  [ -n "$farmslot_dir" ] || farmslot_dir="$HOME/dev/farmslot"
  [ -d "$farmslot_dir/pool" ] || return 1

  TARGET_FOR_CDP="$target" FARMSLOT_FOR_CDP="$farmslot_dir" python3 - <<'INNERPY'
import json, os, socket, subprocess
from pathlib import Path

target = Path(os.environ['TARGET_FOR_CDP']).expanduser().resolve()
root = Path(os.environ['FARMSLOT_FOR_CDP']).expanduser()
pool = root / 'pool'
host = socket.gethostname().split('.')[0]
try:
    local = subprocess.check_output(['scutil', '--get', 'LocalHostName'], stderr=subprocess.DEVNULL, text=True).strip()
except Exception:
    local = ''
preferred = []
for name in dict.fromkeys([host, local]):
    if name:
        preferred.append(pool / f'{name}.json')
preferred.extend(sorted(p for p in pool.glob('*.json') if p not in preferred))

for path in preferred:
    try:
        data = json.loads(path.read_text())
    except Exception:
        continue
    for slot in data.get('slots', []):
        repo = slot.get('repo')
        if not repo:
            continue
        try:
            same = Path(repo).expanduser().resolve() == target
        except Exception:
            same = False
        if not same:
            continue
        port = ((slot.get('resources') or {}).get('browser') or {}).get('cdp_port') or ''
        slot_id = slot.get('id') or ''
        project = slot.get('project') or ''
        if port and slot_id:
            print(f"{root}\t{slot_id}\t{port}\t{project}")
            raise SystemExit(0)
raise SystemExit(1)
INNERPY
}

resolve_extension_cdp_port() {
  local target="$1"
  if [ -n "${CDP_PORT:-}" ]; then
    printf '%s\n' "$CDP_PORT"
    return 0
  fi

  # Local env files are useful outside farmslot. Keep this generic: accept an
  # explicit CDP_PORT assignment only, not repo/slot-specific variable names.
  local env_file line value
  for env_file in "$target/.js.env" "$target/.env" "$target/.env.local"; do
    [ -f "$env_file" ] || continue
    line=$(grep -E '^[[:space:]]*(export[[:space:]]+)?CDP_PORT=' "$env_file" | tail -1 || true)
    [ -n "$line" ] || continue
    value="${line#*=}"
    value="${value%%#*}"
    value="$(printf '%s' "$value" | tr -d "\"'[:space:]")"
    if [ -n "$value" ]; then
      printf '%s\n' "$value"
      return 0
    fi
  done

  local metadata
  if metadata="$(resolve_extension_farmslot_metadata "$target")"; then
    printf '%s\n' "$metadata" | awk -F '\t' '{print $3}'
    return 0
  fi
  return 1
}

run_extension_prepare() {
  local target="$1"
  local cdp_port="$2"
  local metadata="${3:-}"
  local custom_cmd="${MM_HARNESS_EXTENSION_PREPARE_CMD:-}"
  if [ -n "$custom_cmd" ]; then
    log "CDP port $cdp_port is offline; running MM_HARNESS_EXTENSION_PREPARE_CMD"
    log "Build/reuse guard: prefer a cached/watch-only prepare command; do not run a full rebuild unless the caller/human approved it."
    (
      cd "$target"
      TARGET="$target" CDP_PORT="$cdp_port" bash -lc "$custom_cmd"
    )
    return
  fi

  if [ -n "$metadata" ]; then
    local farmslot_dir slot_id _port project preflight watch_mode
    IFS=$'\t' read -r farmslot_dir slot_id _port project <<< "$metadata"
    preflight="$farmslot_dir/projects/$project/setup/preflight.sh"
    watch_mode="${MM_HARNESS_EXTENSION_PREPARE_WATCH:-off}"
    if [ -x "$preflight" ]; then
      log "CDP port $cdp_port is offline; starting extension runtime via Farmslot preflight"
      log "Build/reuse guard: using Farmslot preflight with --watch $watch_mode; if this would rebuild, set MM_HARNESS_EXTENSION_PREPARE_CMD to a cached/watch-only command or disable auto-start."
      bash "$preflight" "$slot_id" --cdp-port "$cdp_port" --mode fullscreen --watch "$watch_mode"
      return
    fi
    log "CDP port $cdp_port is offline and preflight was not found at $preflight"
    return
  fi

  log "CDP port $cdp_port is offline; run extension preflight first, set MM_HARNESS_EXTENSION_PREPARE_CMD, or pass --static-only"
}

if [ "$ADAPTER" = "extension" ] && [ "$ACTION" = "verify" ]; then
  no_auto_start=false
  if has_arg --no-auto-start "$@"; then
    no_auto_start=true
    stripped_args=()
    for arg in "$@"; do
      [ "$arg" = "--no-auto-start" ] && continue
      stripped_args+=("$arg")
    done
    set -- "${stripped_args[@]}"
  fi
  if ! has_arg --cdp-port "$@" && ! has_arg --static-only "$@"; then
    if resolved_cdp_port="$(resolve_extension_cdp_port "$TARGET")"; then
      log "Using CDP port $resolved_cdp_port for extension verify"
      set -- --cdp-port "$resolved_cdp_port" "$@"
    else
      log "Tip: extension live verify needs --cdp-port <port>; use --static-only for static verification."
    fi
  fi
  if ! has_arg --static-only "$@" && ! $no_auto_start && ! is_false "${MM_HARNESS_EXTENSION_AUTO_START:-1}"; then
    args=("$@")
    cdp_arg=""
    for ((i=0; i<${#args[@]}; i++)); do
      case "${args[$i]}" in
        --cdp-port) cdp_arg="${args[$((i + 1))]:-}" ;;
        --cdp-port=*) cdp_arg="${args[$i]#--cdp-port=}" ;;
      esac
    done
    if [ -n "$cdp_arg" ] && ! cdp_reachable "$cdp_arg"; then
      metadata="$(resolve_extension_farmslot_metadata "$TARGET" || true)"
      run_extension_prepare "$TARGET" "$cdp_arg" "$metadata"
    fi
  elif ! has_arg --static-only "$@"; then
    log "Extension auto-start disabled; verify will use the existing CDP runtime only"
  fi
fi

start=$SECONDS
if "$RECIPE_HARNESS" "$ADAPTER" "$ACTION" "$@"; then
  elapsed=$((SECONDS - start))
  log "Done: $ADAPTER $ACTION passed in ${elapsed}s"
else
  status=$?
  elapsed=$((SECONDS - start))
  log "Failed: $ADAPTER $ACTION exited $status after ${elapsed}s"
  exit "$status"
fi
